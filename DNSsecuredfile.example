# DNSsecuredfile
# Caddy-style directive format: <directive> <value(s)>

listen :8080
cors true
default_tenant public
timeout 10s
max_concurrency 4

# Choose exactly the checks you want to run (order matters).
checks ns_redundancy tls_certificate spf dkim_selector_health dmarc mta_sts tls_rpt bimi

# Optional custom resolver targets used by DNS checks.
# Supports host or host:port. Port defaults to 53.
nameservers 1.1.1.1 1.0.0.1 8.8.8.8:53

# Resolver trust mode:
# - system (OS resolver)
# - udp (custom nameservers over UDP/TCP 53)
# - dot (DNS-over-TLS)
# - doh (DNS-over-HTTPS)
resolver_mode dot

# Upstreams for encrypted resolver modes.
dot_upstreams 1.1.1.1 1.0.0.1
# doh_upstreams https://cloudflare-dns.com/dns-query https://dns.google/dns-query

# Optional TLS hardening for dot/doh:
# - tls_server_name enforces SNI/hostname validation target
# - tls_pins are base64 SHA-256 cert pins (with optional sha256/ prefix)
tls_server_name cloudflare-dns.com
# tls_pins sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
